@article{ad4ce47246ed30f5f8ae4145caa535ed72a63d05,
title = {Faster R-CNN With Variable-Sensitive Map for UAVs Fault Detection: Addressing Simultaneous Sensor Faults in Autonomous Flights},
year = {2026},
url = {https://www.semanticscholar.org/paper/ad4ce47246ed30f5f8ae4145caa535ed72a63d05},
abstract = {Unmanned aerial vehicles (UAVs) have advanced significantly and are increasingly used in the civil and military fields. Ensuring their safety and reliability is crucial, and fault detection (FD) is central to secure autonomous flight. Currently, data-driven FD methods have gained significant attention due to their advantage of not relying on the aircraft’s dynamics. However, existing research rarely addresses the simultaneous FD problem for autonomous UAVs during flight. To tackle this challenge, this article proposes a Faster R-convolutional neural network (CNN) model with a variable-sensitive map (VSM). First, data imagefication and image enhancement technologies are employed to facilitate its better adaptation to this model in the machine vision realm. Then, a novel multiple feature map prediction (MFMP) based on VSM is proposed and applied to Faster R-CNN. Furthermore, by modifying the labeling strategy, the model’s accuracy in identifying simultaneous faults is improved. The experimental results show that models in the field of machine vision are feasible for FD in autonomous UAVs and achieve high accuracy compared to mainstream data-driven methods. In addition, experiments designed to detect simultaneous faults demonstrate that the proposed method performs better.},
author = {Jiahao Yu and Changping Du and Rui Yang and Yao Zheng and Zean Du and Tianrui Fang},
journal = {IEEE Transactions on Instrumentation and Measurement},
volume = {75},
pages = {1-11},
doi = {10.1109/TIM.2025.3650267},
}

@article{947d24a67480635615fa2bc20a12f91d94767a66,
title = {Anomaly Detection for Unmanned Aerial Vehicle Sensor Data Using a Stacked Recurrent Autoencoder Method with Dynamic Thresholding},
year = {2022},
url = {https://www.semanticscholar.org/paper/947d24a67480635615fa2bc20a12f91d94767a66},
abstract = {With substantial recent developments in aviation technologies, Unmanned Aerial Vehicles (UAVs) are becoming increasingly integrated in commercial and military operations internationally. Research into the applications of aircraft data is essential in improving safety, reducing operational costs, and developing the next frontier of aerial technology. Having an outlier detection system that can accurately identify anomalous behaviour in aircraft is crucial for these reasons. This paper proposes a system incorporating a Long Short-Term Memory (LSTM) Deep Learning Autoencoder based method with a novel dynamic thresholding algorithm and weighted loss function for anomaly detection of a UAV dataset, in order to contribute to the ongoing efforts that leverage innovations in machine learning and data analysis within the aviation industry. The dynamic thresholding and weighted loss functions showed promising improvements to the standard static thresholding method, both in accuracy-related performance metrics and in speed of true fault detection.},
author = {V. Bell and D. Rengasamy and Benjamin Rothwell and G. Figueredo},
journal = {ArXiv},
volume = {abs/2203.04734},
pages = {null},
doi = {10.48550/arXiv.2203.04734},
arxivid = {2203.04734},
}

@article{539ccd739f1556173148a4913d4e48bced4db7fd,
title = {Intelligent framework for automated failure prediction, detection, and classification of mission critical autonomous flights.},
year = {2022},
url = {https://www.semanticscholar.org/paper/539ccd739f1556173148a4913d4e48bced4db7fd},
abstract = {Autonomous flights are the major industry contributors towards next-generation developments in pervasive and ubiquitous computing. Modern aerial vehicles are designed to receive actuator commands from the primary autopilot software as input to regulate their servos for adjusting control surfaces. Due to real-time interaction with the actual physical environment, there exists a high risk of control surface failures for engine, rudder, elevators, and ailerons etc. If not anticipated and then timely controlled, failures occurring during the flight can have severe and cataclysmic consequences, which may result in mid-air collision or ultimate crash. Humongous amount of sensory data being generated throughout mission-critical flights, makes it an ideal candidate for applying advanced data-driven machine learning techniques to identify intelligent insights related to failures for instant recovery from emergencies. In this paper, we present a novel framework based on machine learning techniques for failure prediction, detection, and classification for autonomous aerial vehicles. The proposed framework utilizes long short-term memory recurrent neural network architecture to analyze time series data and has been applied at the AirLab Failure and Anomaly flight dataset, which is a comprehensive publicly available dataset of various fault types in fixed-wing autonomous aerial vehicles' control surfaces. The proposed framework is able to predict failure with an average accuracy of 93% and the average time-to-predict a failure is 19 s before the actual occurrence of the failure, which is 10 s better than current state-of-the-art. Failure detection accuracy is 100% and average detection time is 0.74 s after happening of failure, which is 1.28 s better than current state-of-the-art. Failure classification accuracy of proposed framework is 100%. The performance analysis shows the strength of the proposed methodology to be used as a real-time failure prediction and a pseudo-real-time failure detection along with a failure classification framework for eventual deployment with actual mission-critical autonomous flights.},
author = {Muhammad Waqas Ahmad and M. Akram and Rashid Ahmad and K. Hameed and Ali Hassan},
journal = {ISA transactions},
volume = {null},
pages = {null},
doi = {10.1016/j.isatra.2022.01.014},
pmid = {35120741},
}

@article{5a116bc3cf4beba3bbb383cdd59c157e12042063,
title = {Fault Diagnosis of Quadrotor UAV Propeller with Local-Global Attention-Based Graph Neural Networks},
year = {2024},
url = {https://www.semanticscholar.org/paper/5a116bc3cf4beba3bbb383cdd59c157e12042063},
abstract = {With the wide application of Quadrotor Unmanned Aerial Vehicles (QUAV) in military and civilian fields, its flight reliability problem has become a hot research topic. The propellers, which are the important components relating to the performance of QUAV, play a central role in safe flight. Traditional data-driven fault diagnosis methods of QUAV are based on Euclidean distance, which cannot effectively capture the interrelationship of multiple variables. In this paper, we treat the fault diagnosis of QUAV propeller as a node classification problem in non-Euclidean infinite dimensional space by introducing the method of Local-Global Attention-based Graph Neural Network (LGA-GNN). First, the graph topology is constructed using the KNN method based on the real flight log of the QUAV. Then, the local and global attention strategies are integrated to form a graph-based collaborative feature extraction model. Finally, a unified end-to-end fault diagnosis framework tailored for QUAV is proposed. In the experiment section, real flight data of QUAV with different propeller fault conditions are collected, and the effectiveness and superiority of the proposed method are verified by comparing with other methods based on real data.},
author = {Zhiwei Wang and Shaojun Liang and Ye Sun and Y. Yang and Yanwei Wang and Ying Zheng},
journal = {2024 IEEE 13th Data Driven Control and Learning Systems Conference (DDCLS)},
volume = {null},
pages = {1057-1062},
doi = {10.1109/DDCLS61622.2024.10606750},
}

@article{235622f17612fb1b852e3443a8946e82709a92b1,
title = {Fault Detection of FW-UAV Based on Spatiotemporal Feature Networks},
year = {2025},
url = {https://www.semanticscholar.org/paper/235622f17612fb1b852e3443a8946e82709a92b1},
abstract = {In fixed-wing unmanned aerial vehicle (FWUAV), anomalous states can propagate errors internally due to the closed-loop nature of flight control systems. This complicates the differentiation of sensor signal variations caused by different component failures, hindering fault detection models from accurately capturing hidden fault features. As a result, FW-UAV may struggle to perceive and interpret critical flight parameters from onboard sensor data, affecting accurate flight state cognition. To address this, we propose a multi-scale fault detection method. Gated Graph Convolutional Networks (GatedGCN) analyze topological relationships between adjacent sensors to extract spatial features, while a CNN-Transformer network captures temporal patterns for precise fault identification. Experiments using real flight data show that this method significantly improves FW-UAV flight state cognition accuracy.},
author = {Junru Li and Fuyang Chen and Yi He},
journal = {2025 IEEE 3rd International Conference on Image Processing and Computer Applications (ICIPCA)},
volume = {null},
pages = {82-86},
doi = {10.1109/ICIPCA65645.2025.11138216},
}

